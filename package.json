{
  "name": "git-look-around",
  "description": "GitHub Look-Around browser extension",
  "private": true,
  "version": "0.3.3",
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--no-webstorage' wxt",
    "dev:firefox": "NODE_OPTIONS='--no-webstorage' wxt -b firefox",
    "build": "NODE_OPTIONS='--no-webstorage' wxt build",
    "build:firefox": "NODE_OPTIONS='--no-webstorage' wxt build -b firefox",
    "zip": "NODE_OPTIONS='--no-webstorage' wxt zip",
    "zip:firefox": "NODE_OPTIONS='--no-webstorage' wxt zip -b firefox",
    "compile": "NODE_OPTIONS='--no-webstorage' vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "NODE_OPTIONS='--no-webstorage' wxt prepare"
  },
  "dependencies": {
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@wxt-dev/module-vue": "^1.0.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.9.2",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.7",
    "wxt": "^0.20.27"
  }
}
